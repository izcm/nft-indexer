{
  "name": "dmrkt-indexer",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "nodemon --exec node --conditions=dev --loader ts-node/esm app/index.ts",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "build": "tsc",
    "start": "node --conditions=prod dist/app/index.js",
    "fmt": "prettier --write .",
    "prepare": "husky",
    "clean": "rm -rf dist build && rm -rf .cache"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@a2zb/abis": "1.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^11.1.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "mongodb": "^7.0.0",
    "tsconfig-paths": "^4.2.0",
    "viem": "^2.42.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "prettier": "3.7.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "config": {},
  "imports": {
    "#app/*": {
      "dev": "./app/*",
      "prod": "./dist/app/*"
    }
  }
}
